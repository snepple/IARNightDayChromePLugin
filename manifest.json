{
  "manifest_version": 3,
  "name": "IamResponding Auto Theme",
  "version": "1.0",
  "description": "Automatically switches IamResponding dashboard between light and dark modes based on sunrise and sunset.",
  "permissions": [
    "storage",
    "alarms",
    "offscreen",
    "geolocation"
  ],
  "host_permissions": [
    "https://dashboard.iamresponding.com/*",
    "https://api.sunrise-sunset.org/*",
    "https://auth.iamresponding.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.iamresponding.com/*"
      ],
      "js": [
        "content-loader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://auth.iamresponding.com/*"
      ],
      "js": [
        "login-loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "utils.js",
        "content.js",
        "login.js"
      ],
      "matches": [
        "https://dashboard.iamresponding.com/*",
        "https://auth.iamresponding.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IamResponding Auto Theme"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}